#!/bin/sh
set -eu

echo "🔄 Checking for markdown files to convert..."

REPO_ROOT="$(git rev-parse --show-toplevel)"
CSS_FILE="$REPO_ROOT/scripts/help-style.css"

if [ ! -f "$CSS_FILE" ]; then
  echo "❌ CSS file not found: $CSS_FILE"
  exit 1
fi

if [ -x "$REPO_ROOT/node_modules/.bin/marked" ]; then
  MARKED_BIN="$REPO_ROOT/node_modules/.bin/marked"
elif command -v marked >/dev/null 2>&1; then
  MARKED_BIN="$(command -v marked)"
else
  echo "❌ 'marked' command not found."
  echo "   Install it with 'npm install -g marked'."
  exit 1
fi

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files detected."
  exit 0
fi

CSS_CHANGED=0
if printf '%s\n' "$STAGED_FILES" | grep -Eq '^scripts/help-style\.css$'; then
  CSS_CHANGED=1
fi

CHANGED_MD_FILES="$(printf '%s\n' "$STAGED_FILES" | grep -E '^HelpContent/.*\.md$' || true)"

if [ "$CSS_CHANGED" -eq 1 ]; then
  MD_RELATIVE_FILES="$(find "$REPO_ROOT/HelpContent" -type f -name '*.md' | LC_ALL=C sort | sed "s#^$REPO_ROOT/##")"
else
  MD_RELATIVE_FILES="$CHANGED_MD_FILES"
fi

if [ -z "$MD_RELATIVE_FILES" ]; then
  echo "No markdown or style changes detected."
  exit 0
fi

OLD_IFS=$IFS
IFS='
'

for RELATIVE_PATH in $MD_RELATIVE_FILES; do
  [ -n "$RELATIVE_PATH" ] || continue

  MD_FILE="$REPO_ROOT/$RELATIVE_PATH"
  HTML_FILE="${MD_FILE%.md}.html"
  TMP_FILE="${HTML_FILE}.tmp"
  LANG="$(basename "$MD_FILE" .md)"
  BODY="$("$MARKED_BIN" "$MD_FILE")"
  BODY="$(printf '%s\n' "$BODY" | sed 's|<table>|<div class="table-wrapper"><table>|g; s|</table>|</table></div>|g')"
  CSS="$(cat "$CSS_FILE")"

  cat > "$TMP_FILE" <<HTMLEOF
<!DOCTYPE html>
<html lang="${LANG}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <style>
${CSS}
  </style>
</head>
<body>
${BODY}
</body>
</html>
HTMLEOF

  mv "$TMP_FILE" "$HTML_FILE"
  git add "$HTML_FILE"
  echo "  ✓ $(basename "$MD_FILE") → $(basename "$HTML_FILE")"
done

IFS=$OLD_IFS

echo "✅ Done."
